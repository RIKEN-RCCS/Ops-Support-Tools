SUPPORT_AI_QUEUE_DIR=/data/queue
SUPPORT_AI_QUEUE_DB=/data/queue/queue.sqlite
SUPPORT_AI_AGENTS_FILE=/config/agents.json
SUPPORT_AI_AGENTS_TEMPLATE_FILE=/app/agents.example.json
SUPPORT_AI_STARTUP_CHECKS=1
SUPPORT_AI_STARTUP_RETRIES=3
SUPPORT_AI_STARTUP_RETRY_DELAY=5
SUPPORT_AI_SYNC_AGENTS_ON_STARTUP=1
SUPPORT_AI_SYNC_AGENTS_ON_POST=1
SUPPORT_AI_LIGHT_AGENT_ROLE_TYPE=1
SUPPORT_AI_ASSIGNEE_FIELD_ID=
SUPPORT_AI_TRIAGE_TAG=ai_triaged
SUPPORT_AI_TRIAGE_SEARCH_QUERY=type:ticket status:new -tags:ai_triaged
SUPPORT_AI_KNOWLEDGE_API_URL=http://knowledge-api:8080
SUPPORT_AI_CREATE_KNOWLEDGE_RUNS=1

# OpenAI-compatible LLM endpoint.
LLM_BASE_URL=https://api.example.com/v1
SUPPORT_AI_MODEL=replace-with-model
SUPPORT_AI_FALLBACK_MODELS=
SUPPORT_AI_RUNBOOK_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
SUPPORT_AI_RUNBOOK_FALLBACK_MODELS=Qwen/Qwen3.6-27B-FP8,zai-org/GLM-4.7-FP8
SUPPORT_AI_LLM_HEALTHCHECK_PATH=/models
SUPPORT_AI_CONTEXT=あなたは組織内サポートデスクの一次トリアージ担当です。

# Zendesk API token credentials. The token itself goes in secrets/zendesk_key.
ZENDESK_URL=https://your-subdomain.zendesk.com
ZENDESK_EMAIL=agent@example.com

# Production Docker secrets are stored in app-local files, not in .env:
#   apps/zendesk-support-ai/secrets/llm_api_key
#   apps/zendesk-support-ai/secrets/zendesk_key
#   apps/zendesk-support-ai/secrets/support_ai_webhook_token
#   apps/zendesk-support-ai/secrets/support_ai_queue_key
#
# Local non-Docker runs may still set these environment variables directly:
#   LLM_API_KEY
#   ZENDESK_KEY
#   SUPPORT_AI_WEBHOOK_TOKEN
#   SUPPORT_AI_QUEUE_KEY
