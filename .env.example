TRIAGE_SPOOL_DIR=/data/spool
TRIAGE_AGENTS_FILE=/config/agents.json
TRIAGE_AGENTS_TEMPLATE_FILE=/app/agents.example.json
TRIAGE_STARTUP_CHECKS=1
TRIAGE_STARTUP_RETRIES=3
TRIAGE_STARTUP_RETRY_DELAY=5
TRIAGE_SYNC_AGENTS_ON_STARTUP=1
TRIAGE_SYNC_AGENTS_ON_POST=1
TRIAGE_LIGHT_AGENT_ROLE_TYPE=1
TRIAGE_TAG=ai_triaged
TRIAGE_SEARCH_QUERY=type:ticket status:new -tags:ai_triaged

# Optional shared secret for Zendesk webhook requests.
TRIAGE_WEBHOOK_TOKEN=replace-me

# OpenAI-compatible LLM endpoint.
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-me
TRIAGE_MODEL=replace-with-model
TRIAGE_FALLBACK_MODELS=
TRIAGE_LLM_HEALTHCHECK_PATH=/models
TRIAGE_SUPPORT_CONTEXT=あなたは組織内サポートデスクの一次トリアージ担当です。

# Zendesk API token credentials.
ZENDESK_URL=https://your-subdomain.zendesk.com
ZENDESK_EMAIL=agent@example.com
ZENDESK_KEY=replace-me
